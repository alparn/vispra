{
  "name": "vispra",
  "description": "Modern HTML5 client for Xpra built with SolidJS and TypeScript",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "XPRA_TEST_URL=ws://localhost:10000 vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "brotli-wasm": "^3.0.0",
    "file-saver": "^2.0.5",
    "lz4js": "^0.2.0",
    "simple-keyboard": "^3.8.0",
    "solid-js": "^1.9.0",
    "streamsaver": "^2.0.6"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.3.5",
    "@types/streamsaver": "^2.0.5",
    "@types/ws": "^8.18.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0",
    "ws": "^8.19.0"
  }
}
